(*  ODRL_Periodic.thy  --  def:ti-rec, lem:rec (Sec. 3.1) *)
theory ODRL_Periodic
  imports ODRL_Structures "HOL-Computational_Algebra.Computational_Algebra"
begin

text \<open>def:ti-rec. The periodic set of an anchor a and period p>0 is the orbit of a
      under shifting by p, indexed by \<int>.\<close>

definition Per :: "inst \<Rightarrow> dur \<Rightarrow> inst set" where
  "Per a p = {a + of_int k * p | k. True}"

lemma Per_mem_iff: "x \<in> Per a p \<longleftrightarrow> (\<exists>k::int. x = a + of_int k * p)"
  by (auto simp: Per_def)

text \<open>Intersection-nonempty in existence form. This part is essentially the
      definition of the orbit and is mechanical.\<close>

lemma Per_inter_nonempty_iff:
  "Per a1 p1 \<inter> Per a2 p2 \<noteq> {}
     \<longleftrightarrow> (\<exists>k j::int. a2 - a1 = of_int k * p1 - of_int j * p2)"
  \<comment> \<open>[routine] x in both \<longleftrightarrow> \<exists>k j. a1 + k p1 = a2 + j p2 \<longleftrightarrow> a2 - a1 = k p1 - j p2.
       Try (auto simp: Per_def) then existential massaging / algebra.\<close>
  sorry

text \<open>def:lem:rec, gcd form. With p1,p2 rational, the integer combinations
      {k p1 + j p2} form a cyclic subgroup of (\<rat>,+) generated by gcd(p1,p2).\<close>

definition rat_gcd :: "rat \<Rightarrow> rat \<Rightarrow> rat" where
  \<comment> \<open>positive generator of p1\<int> + p2\<int> \<subseteq> (\<rat>,+). Implement by clearing denominators:
     write p1 = n1/m, p2 = n2/m over a common denom m>0, then
     rat_gcd p1 p2 = (of_int (gcd n1 n2)) / (of_int m).\<close>
  "rat_gcd p1 p2 =
     (let m  = of_int (lcm (snd (quotient_of p1)) (snd (quotient_of p2)));
          n1 = p1 * m; n2 = p2 * m
      in (of_int (gcd \<lfloor>n1\<rfloor> \<lfloor>n2\<rfloor>)) / m)"

definition rat_dvd :: "rat \<Rightarrow> rat \<Rightarrow> bool" (infix \<open>rdvd\<close> 50) where
  "g rdvd d \<longleftrightarrow> (\<exists>k::int. d = of_int k * g)"

theorem rec_gcd:                              \<comment> \<open>lem:rec\<close>
  assumes "p1 > 0" "p2 > 0"
  shows   "Per a1 p1 \<inter> Per a2 p2 \<noteq> {} \<longleftrightarrow> rat_gcd p1 p2 rdvd (a2 - a1)"
  \<comment> \<open>[main, ~1 week]. Plan: via Per_inter_nonempty_iff reduce to
       a2-a1 \<in> {k p1 - j p2}. Scale by the common denominator m so n1=p1 m, n2=p2 m,
       \<Delta>=(a2-a1) m are integers; then {k n1 - j n2} = gcd(n1,n2).\<int> by Bezout
       (HOL-Computational_Algebra: bezout / Gcd over int), so membership \<longleftrightarrow>
       gcd(n1,n2) | \<Delta> \<longleftrightarrow> rat_gcd p1 p2 rdvd (a2-a1). Divide back by m.\<close>
  sorry

text \<open>Forward-only reading (guard now \<ge> anchor) drops negative k without changing
      any verdict (paper, Sec. 3.1).\<close>

definition Per_fwd :: "inst \<Rightarrow> dur \<Rightarrow> inst set" where
  "Per_fwd a p = {a + of_int k * p | k. 0 \<le> k}"

lemma Per_fwd_subset: "Per_fwd a p \<subseteq> Per a p"
  by (auto simp: Per_fwd_def Per_def)

end
