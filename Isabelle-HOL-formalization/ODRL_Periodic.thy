text ‹Forward-only reading (guard now ≥ anchor) drops negative k without changing
      any verdict (paper, Sec. 3.1).›

definition Per_fwd :: "inst ⇒ dur ⇒ inst set" where
  "Per_fwd a p = {a + of_int k * p | k. 0 ≤ k}"

lemma Per_fwd_subset: "Per_fwd a p ⊆ Per a p"
  by (auto simp: Per_fwd_def Per_def)

end
