theory ODRL_Periodic
  imports ODRL_Structures "HOL-Computational_Algebra.Computational_Algebra"
begin

text ‹def:ti-rec. The periodic set of an anchor a and period p>0 is the orbit of a
      under shifting by p, indexed by ℤ.›

definition Per :: "inst ⇒ dur ⇒ inst set" where
  "Per a p = {a + of_int k * p | k. True}"

lemma Per_mem_iff: "x ∈ Per a p ⟷ (∃k::int. x = a + of_int k * p)"
  by (auto simp: Per_def)

text ‹Intersection-nonempty in existence form. This part is essentially the
      definition of the orbit and is mechanical.›

lemma Per_inter_nonempty_iff:
  "Per a1 p1 ∩ Per a2 p2 ≠ {}
     ⟷ (∃k j::int. a2 - a1 = of_int k * p1 - of_int j * p2)"
  ― ‹[routine] x in both ⟷ ∃k j. a1 + k p1 = a2 + j p2 ⟷ a2 − a1 = k p1 − j p2.
       Try (auto simp: Per_def) then existential massaging / algebra.›
  sorry

text ‹def:lem:rec, gcd form. With p1,p2 rational, the integer combinations
      {k p1 + j p2} form a cyclic subgroup of (ℚ,+) generated by gcd(p1,p2).›

definition rat_gcd :: "rat ⇒ rat ⇒ rat" where
  ― ‹positive generator of p1ℤ + p2ℤ ⊆ (ℚ,+). Implement by clearing denominators:
     write p1 = n1/m, p2 = n2/m over a common denom m>0, then
     rat_gcd p1 p2 = (of_int (gcd n1 n2)) / (of_int m).›
  "rat_gcd p1 p2 =
     (let m  = of_int (lcm (snd (quotient_of p1)) (snd (quotient_of p2)));
          n1 = p1 * m; n2 = p2 * m
      in (of_int (gcd ⌊n1⌋ ⌊n2⌋)) / m)"

definition rat_dvd :: "rat ⇒ rat ⇒ bool" (infix ‹rdvd› 50) where
  "g rdvd d ⟷ (∃k::int. d = of_int k * g)"

theorem rec_gcd:                              ― ‹lem:rec›
  assumes "p1 > 0" "p2 > 0"
  shows   "Per a1 p1 ∩ Per a2 p2 ≠ {} ⟷ rat_gcd p1 p2 rdvd (a2 - a1)"
